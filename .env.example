# ============================================================
#  Znuny 7.3.4 Helpdesk - Plantilla de variables de entorno
#  Copia a .env y cambia las contraseñas:
#     cp .env.example .env
#  Genera contraseñas seguras, p.ej.:
#     openssl rand -base64 18 | tr -d '/+=' | head -c 24
# ============================================================

# --- Base de datos (PostgreSQL) ---
ZNUNY_DB_TYPE=postgresql
ZNUNY_DB_HOST=postgres
ZNUNY_DB_PORT=5432
ZNUNY_DB_NAME=znuny
ZNUNY_DB_USER=znuny
ZNUNY_DB_PASSWORD=CAMBIAME_db

# --- Instalación automática ---
# true = crea la BD, importa el esquema y aplica ZNUNY_ROOT_PASSWORD
#        en el primer arranque (idempotente). Déjalo en true.
ZNUNY_AUTO_INSTALL=true

# --- Administrador de Znuny ---
# Usuario de acceso web: root@localhost
ZNUNY_ROOT_PASSWORD=CAMBIAME_admin

# --- Sistema ---
ZNUNY_SYSTEM_ID=10
ZNUNY_FQDN=localhost
ZNUNY_ADMIN_EMAIL=admin@example.com
ZNUNY_ORGANIZATION=Helpdesk
